
# .env 文件
SAV_USERNAME=your_username
SAV_PASSWORD=your_password
SAV_EXPORT_TIMEOUT_MS=30000
SAV_STORAGE_STATE_PATH=.sav-storage-state.json
SAV_NO_SANDBOX=false

# 邮箱 IMAP 配置 (以 QQ 邮箱或网易邮箱为例，Gmail 需要应用专用密码)
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your application password
EMAIL_HOST=imap.example.com  # 如果是网易填 imap.163.com，Gmail 填 imap.gmail.com